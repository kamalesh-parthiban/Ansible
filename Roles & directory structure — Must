---------------
Project A's complete playbook.yml:

---
- name: setup project a web server
  hosts: webservers
  become: yes
  become_user: root
  gather_facts: yes

  vars:
    env: production
    app_port: 8080

  pre_tasks:
    - name: update yum cache
      yum:
        update_cache: yes

  roles:
    - nginx        # calls roles/nginx/tasks/main.yml
    - mysql        # calls roles/mysql/tasks/main.yml

  post_tasks:
    - name: verify nginx is running
      service:
        name: nginx
        state: started

    - name: verify mysql is running
      service:
        name: mysql
        state: started
------------------------------------------------------
What happens when you run this:

ansible-playbook playbook.yml
        ↓
pre_tasks  → update yum cache
        ↓
roles/nginx/tasks/main.yml  → install + configure nginx
        ↓
roles/mysql/tasks/main.yml  → install + configure mysql
        ↓
post_tasks → verify both services running
-----------------------------------------------------
Ansible automatically finds roles by name from the roles/ folder next to the playbook; you only need to specify a path 
if roles are stored in a non-default location, which you configure via ansible.cfg or absolute path in the playbook.
--------------------------------------------------------------------------------------

Under role

# roles/nginx/tasks/main.yml

- name: install nginx
  yum:
    name: "{{ package_name }}"       # picks from defaults/main.yml ✅
    state: present
  tags:
    - install

- name: copy config
  template:
    src: nginx.conf.j2
    dest: "{{ config_path }}/nginx.conf"
  notify: restart nginx
  tags:
    - config

- name: start nginx
  service:
    name: nginx
    state: started
    enabled: yes
  tags:
    - start


# roles/nginx/handlers/main.yml

- name: restart nginx
  service:
    name: nginx
    state: restarted


# roles/nginx/defaults/main.yml

package_name: nginx
http_port: 80
worker_processes: auto


# roles/nginx/vars/main.yml

config_path: /etc/nginx
log_path: /var/log/nginx


# roles/nginx/templates/nginx.conf.j2

worker_processes {{ worker_processes }};

http {
    server {
        listen {{ http_port }};
        server_name {{ ansible_hostname }};
    }
}
